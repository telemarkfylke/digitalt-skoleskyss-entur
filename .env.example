# SQL Server Configuration
DB_SERVER="your_server_name_or_localhost"
DB_PORT="1433"
DB_DATABASE="your_database_name"
DB_USER="your_username"
DB_PASSWORD="your_password"
DB_TRUST_SERVER_CERTIFICATE="true"
DB_ENCRYPT="true"

ENTUR_AUDIENCE="https://api.<your_entur_env_empty_if_prod>.entur.io"
ENTUR_CLIENT_ID="your_client_id"
ENTUR_CLIENT_SECRET="your_client_secret"
ENTUR_TOKEN_URL="https://partner.<your_entur_env_empty_if_prod>.entur.org/oauth/token"
ENTUR_API_URL="https://api.<your_entur_env_empty_if_prod>.entur.io/skoleskyss"

# Application Configuration
NODE_ENV="development" #[development/production]
APP_NAME="your_app_name"

# Queue configuration (used with --method queue)
SYNC_QUEUE_LIMIT="10"                           # Students per run (0 = send all pending)
SYNC_QUEUE_FILE="./queue/sync-queue.json"       # Path to the persistent queue file
SYNC_QUEUE_REBUILD="false"                      # Force rebuild queue from DB on next run

# Fare contract defaults — applied to all students unless overridden by fareContractRules
# (Edit src/config/fare-contract-config.ts to add per-school/class overrides)
ENTUR_AUTHORITY_ID="TEL:Authority:Telemark"
ENTUR_DEFAULT_CALENDAR_ID="TEL:FareDayType:SchoolDayDefaultSchool20252026"
ENTUR_DEFAULT_TIMEBANDS_START="5"
ENTUR_DEFAULT_TIMEBANDS_END="18"
ENTUR_VALIDABLE_ELEMENT_ID=""
ENTUR_FARE_PRODUCT_ID=""
ENTUR_USER_PROFILE_ID=""

# Logging 
BETTERSTACK_URL= "https://your_betterstack_endpoint_url",
BETTERSTACK_TOKEN= "your_betterstack_token",
BETTERSTACK_MIN_LOG_LEVEL= "WARN",
CONSOLE_ENABLED= "true",
CONSOLE_MIN_LOG_LEVEL= "debug",
TEAMS_WEBHOOK_URL= "https://your_teams_webhook_url",
TEAMS_MIN_LOG_LEVEL= "ERROR",
